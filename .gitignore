# UPF Scanner - .gitignore

# Node modules (if using any build tools in future)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (if build step added later)
dist/
build/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Chrome extension development
*.pem
*.crx
*.zip

# Store assets - large video files (not committed to repo)
store-assets/*.mp4

# Tesco test fixture pages (saved HTML — not redistributed)
test/pages/

# Claude Code local settings
.claude/
.mcp.json

# Git worktrees (isolated development workspaces)
.worktrees/

# Environment variables (if ever needed)
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# Cache
.cache/
.parcel-cache/

# Coverage reports (if tests added)
coverage/
.nyc_output/

# macOS
.AppleDouble
.LSOverride

# Windows
ehthumbs.db
*.stackdump

# Linux
.directory

# Backup files
*.bak
*.backup
*~

# yarn.lock — not used; package-lock.json is tracked for reproducible installs
# yarn.lock
