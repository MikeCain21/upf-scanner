{
  "name": "upf-scanner",
  "version": "1.3.2",
  "description": "Chrome extension that identifies ultra-processed foods on UK supermarket websites using NOVA classification",
  "main": "manifest.json",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:verbose": "jest --verbose",
    "test:connectivity": "jest --config jest.connectivity.config.js test/connectivity/openfoodfacts-connectivity.test.js --verbose",
    "test:coverage": "jest --coverage",
    "lint": "eslint background/ content/ lib/ popup/",
    "format": "prettier --write background/ content/ lib/ popup/ test/unit/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MikeCain21/upf-scanner.git"
  },
  "keywords": [
    "chrome-extension",
    "nova",
    "ultra-processed",
    "food",
    "health",
    "nutrition",
    "tesco",
    "supermarket",
    "openfoodfacts"
  ],
  "author": "MikeCain21",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MikeCain21/upf-scanner/issues"
  },
  "homepage": "https://github.com/MikeCain21/upf-scanner#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
